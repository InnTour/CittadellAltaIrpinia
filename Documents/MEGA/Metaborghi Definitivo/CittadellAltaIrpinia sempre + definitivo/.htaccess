<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Do not rewrite API requests — let PHP handle them
  RewriteRule ^api/ - [L]

  # Do not rewrite requests for existing files or directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Redirect everything else to index.html (SPA fallback)
  RewriteRule ^ index.html [L]
</IfModule>

# ─── Compressione GZIP ───────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css \
    application/javascript application/json application/ld+json \
    application/xhtml+xml image/svg+xml font/woff2
</IfModule>

# ─── Security Headers ────────────────────────────────────────
<IfModule mod_headers.c>
  # X-Frame-Options rimosso: sostituito da CSP frame-ancestors (più preciso e moderno)
  # Consente iframe da Treedis virtual tour e da metaborghi.org stesso
  Header always set Content-Security-Policy "frame-ancestors 'self' https://my.treedis.com https://*.treedis.com"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  Header always set X-XSS-Protection "1; mode=block"

  # Cache: HTML prerendered — 1 ora, poi rivalidazione
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # Cache: asset Vite con content-hash nel filename — 1 anno immutabile
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache: font, immagini, icone — 30 giorni
  <FilesMatch "\.(woff2|woff|ttf|otf|svg|png|jpg|jpeg|webp|ico|gif)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
