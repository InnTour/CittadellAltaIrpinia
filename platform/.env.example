# ElevenLabs API Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API Configuration (for Claude Alternative or GPT-4)
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (PostgreSQL - Future)
DATABASE_URL=postgresql://user:password@localhost:5432/metaborghi

# PHP Legacy API (for Strangler Fig migration)
PHP_API_BASE=https://your-php-api-domain.com

# Analytics (Optional)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_id

# Environment
NODE_ENV=development
