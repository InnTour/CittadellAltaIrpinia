<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Do not rewrite API requests — let PHP handle them
  RewriteRule ^api/ - [L]

  # Do not rewrite requests for existing files or directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Redirect everything else to index.html (SPA fallback)
  RewriteRule ^ index.html [L]
</IfModule>

# Prevent caching of JS/CSS assets so updated files are always served fresh
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
